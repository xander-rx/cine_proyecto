body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background-color:#141414;
    color:white;
}

header{
    background-color:#000;
    padding:20px;
    text-align:center;
}

h1{
    color:#e50914;
}

.catalogo{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
    padding:30px;
}

.pelicula{
    background-color:#1f1f1f;
    width:200px;
    border-radius:10px;
    overflow:hidden;
    text-align:center;
    transition: transform 0.3s, box-shadow 0.3s;
}

.pelicula img{
    width:100%;
    height:300px;
    object-fit:cover;
}

.pelicula h3{
    margin:10px 0 5px 0;
}

.pelicula p{
    font-size:14px;
    padding:0 10px 15px 10px;
    color:#ccc;
}

.pelicula:hover{
    transform:scale(1.08);
    box-shadow:0 0 15px rgba(229,9,20,0.7);
}
